# ===========================================
# SIMRP - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
# ===========================================

# -------------------------------------------
# APPLICATION ENVIRONMENT
# -------------------------------------------
# Options: development, production
# Default: development
SIMRP_ENV=development

# -------------------------------------------
# DATABASE CONFIGURATION
# -------------------------------------------
# Path to SQLite database file
# Default: ./database/runtime/database.db
SIMRP_DB_PATH=./database/runtime/database.db

# -------------------------------------------
# SECURITY - PASSWORD HASHING
# -------------------------------------------
# PBKDF2 iterations for password hashing
# Default: 210000 (development), increase to 600000+ for production
SIMRP_PBKDF2_ITERATIONS=210000

# -------------------------------------------
# SECURITY - ADMIN CREDENTIALS
# -------------------------------------------
# IMPORTANT: Change these before production deployment!
# Admin login username (for /admin page)
SIMRP_ADMIN_LOGIN_USERNAME=admin
# Admin login password - leave empty in local development to generate database/runtime/dev_credentials.txt.
# Production must provide a strong unique password (min 16 chars).
SIMRP_ADMIN_LOGIN_PASSWORD=

# -------------------------------------------
# SECURITY - SESSION MANAGEMENT
# -------------------------------------------
# Session TTL in hours
# Default: 168h (7 days) for development, 24h for production
SIMRP_SESSION_TTL_HOURS=24

# -------------------------------------------
# SECURITY - RATE LIMITING
# -------------------------------------------
# Rate limit window in seconds
SIMRP_RATE_LIMIT_WINDOW_SECONDS=60
# Max auth attempts per window (login, signup, admin-login)
SIMRP_RATE_LIMIT_AUTH_MAX=10
# Max mutation requests per window (POST, PUT, DELETE)
SIMRP_RATE_LIMIT_MUTATION_MAX=120

# -------------------------------------------
# SECURITY - REQUEST LIMITS
# -------------------------------------------
# Maximum request body size in bytes (default: 8MB)
SIMRP_MAX_BODY_BYTES=8388608

# -------------------------------------------
# CORS - ALLOWED ORIGINS
# -------------------------------------------
# Comma-separated list of allowed origins
# Development defaults: http://localhost:5173, http://127.0.0.1:5173
# For production, add your domain:
# SIMRP_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SIMRP_ALLOWED_ORIGINS=

# Trust X-Forwarded-For only when the app is behind a trusted reverse proxy
# that strips incoming spoofed proxy headers.
SIMRP_TRUST_PROXY_HEADERS=false

# -------------------------------------------
# SECURITY - SEED DATA
# -------------------------------------------
# Demo seed defaults to true in development and false in production.
SIMRP_ENABLE_DEMO_SEED=false
# Password for seeded demo accounts (NOT for admin).
# Leave empty in local development to generate database/runtime/dev_credentials.txt.
# Required if SIMRP_ENABLE_DEMO_SEED=true in production.
SIMRP_DEMO_PASSWORD=
# Password for initial admin user bootstrap on a fresh database.
# Leave empty to reuse SIMRP_ADMIN_LOGIN_PASSWORD for the bootstrap user.
# Required only if you need a separate password for admin@simrp.local.
SIMRP_SEED_ADMIN_PASSWORD=

# -------------------------------------------
# FRONTEND - VITE CONFIGURATION
# -------------------------------------------
# API Base URL for frontend
# Default: http://127.0.0.1:8000/make-server-32aa5c5c
VITE_API_BASE_URL=http://127.0.0.1:8000/make-server-32aa5c5c

# -------------------------------------------
# PRODUCTION CHECKLIST
# -------------------------------------------
# Before deploying to production:
# [ ] Set SIMRP_ENV=production
# [ ] Change SIMRP_ADMIN_LOGIN_PASSWORD to a strong password (min 16 chars)
# [ ] Set SIMRP_PBKDF2_ITERATIONS=600000 or higher
# [ ] Set SIMRP_SESSION_TTL_HOURS=24 or less
# [ ] Configure SIMRP_ALLOWED_ORIGINS with your domain
# [ ] Keep SIMRP_ENABLE_DEMO_SEED=false, or set SIMRP_DEMO_PASSWORD and SIMRP_SEED_ADMIN_PASSWORD
# [ ] Enable HTTPS (reverse proxy with SSL/TLS)
# [ ] Review rate limiting settings
# [ ] Enable audit logging
# [ ] Set up database backups
# -------------------------------------------

# -------------------------------------------
# AI SECURITY AGENT - PROMPT CACHING
# -------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Optional model overrides.
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-v4-pro
QWEN_MODEL=qwen3.5-plus
